<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.test.mapper.PointMapper">

    <resultMap id="pointHistoryResultMap" type="com.test.dto.PointHistoryDto">
        <id     property="id"        column="id"/>
        <result property="memberId"  column="member_id"/>
        <result property="orderId"   column="order_id"/>
        <result property="amount"    column="amount"/>
        <result property="type"      column="type"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insertHistory" parameterType="com.test.dto.PointHistoryDto" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO point_history (member_id, order_id, amount, type, created_at)
        VALUES (#{memberId}, #{orderId}, #{amount}, #{type}, NOW())
    </insert>

    <select id="findByMemberId" parameterType="long" resultMap="pointHistoryResultMap">
        SELECT id, member_id, order_id, amount, type, created_at
        FROM point_history
        WHERE member_id = #{memberId}
        ORDER BY created_at DESC
    </select>

</mapper>
