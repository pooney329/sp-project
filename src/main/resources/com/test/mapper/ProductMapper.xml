<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.test.mapper.ProductMapper">

    <resultMap id="productResultMap" type="com.test.dto.ProductDto">
        <id     property="id"          column="id"/>
        <result property="name"        column="name"/>
        <result property="price"       column="price"/>
        <result property="stock"       column="stock"/>
        <result property="description" column="description"/>
        <result property="createdAt"   column="created_at"/>
    </resultMap>

    <select id="findAll" resultMap="productResultMap">
        SELECT id, name, price, stock, description, created_at
        FROM product
        ORDER BY created_at DESC
    </select>

    <select id="findById" parameterType="long" resultMap="productResultMap">
        SELECT id, name, price, stock, description, created_at
        FROM product
        WHERE id = #{id}
    </select>

    <update id="decreaseStock">
        UPDATE product
        SET stock = stock - #{param2}
        WHERE id = #{param1}
          AND stock >= #{param2}
    </update>

</mapper>
